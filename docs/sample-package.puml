@startuml Package Diagram

top to bottom direction
skinparam class<<component>> {
  BackgroundColor #4A90D9
}
skinparam class<<derived>> {
  BackgroundColor #9B59B6
}
skinparam class<<endpoint>> {
  BackgroundColor #E74C3C
}
skinparam class<<error-page>> {
  BackgroundColor #C0392B
}
skinparam class<<Exported>> {
  BackgroundColor #95A5A6
}
skinparam class<<function>> {
  BackgroundColor #3498DB
}
skinparam class<<layout>> {
  BackgroundColor #2ECC71
}
skinparam class<<LayoutLoad>> {
  BackgroundColor #1ABC9C
}
skinparam class<<page>> {
  BackgroundColor #27AE60
}
skinparam class<<PageLoad>> {
  BackgroundColor #16A085
}
skinparam class<<state>> {
  BackgroundColor #E74C3C
}
skinparam class<<store>> {
  BackgroundColor #E67E22
}
legend right
  |= component |= #4A90D9 |
  |= derived |= #9B59B6 |
  |= endpoint |= #E74C3C |
  |= error-page |= #C0392B |
  |= Exported |= #95A5A6 |
  |= function |= #3498DB |
  |= layout |= #2ECC71 |
  |= LayoutLoad |= #1ABC9C |
  |= page |= #27AE60 |
  |= PageLoad |= #16A085 |
  |= state |= #E74C3C |
  |= store |= #E67E22 |
endlegend

package "lib" as lib {
  class "Button" <<component>>
  class "clearUser" <<function>> <<Exported>>
  class "setUser" <<function>> <<Exported>>
  class "userStore" <<store>>
}

package "routes" as routes {
  class "+layout" <<component>>
  class "+layout" <<layout>>
  class "+page" <<component>>
  class "+page" <<component>>
  class "+page" <<page>>
  class "+page" <<page>>
  class "+server" <<endpoint>>
  class "GET" <<function>> <<Exported>>
  class "load" <<function>> <<Exported>>
  class "load" <<function>> <<Exported>>
  class "POST" <<function>> <<Exported>>
}

routes ..> lib : 1

@enduml